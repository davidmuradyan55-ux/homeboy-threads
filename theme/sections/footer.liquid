        },
        {
          "type": "url",
          "id": "link_6_url",
          "label": "Link 6 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "title": "Shop",
            "link_1_text": "All Items",
            "link_1_url": "/collections/all",
            "link_2_text": "Reformation",
            "link_2_url": "/collections/reformation",
            "link_3_text": "Guess",
            "link_3_url": "/collections/guess",
            "link_4_text": "Dresses",
            "link_4_url": "/collections/dresses",
            "link_5_text": "Denim",
