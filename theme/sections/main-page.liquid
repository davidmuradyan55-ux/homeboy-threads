{%- comment -%}
  Section: Main Page
  Default page template content
{%- endcomment -%}

<div style="padding: 60px var(--page-gutter, 40px); max-width: 800px; margin: 0 auto;">
  <h1 style="font-family: var(--serif); font-size: 42px; font-weight: 400; letter-spacing: -0.02em; margin-bottom: 24px;">{{ page.title }}</h1>
  <div style="font-size: 15px; color: var(--mid); line-height: 1.8;">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "settings": []
}
{% endschema %}
